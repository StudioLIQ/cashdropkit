# CashDrop Kit Root Environment Configuration
# Single source of truth for Web + API.
# 1) Copy to .env.local for local development
# 2) On Vercel/Railway, set the same keys in each service dashboard

# ============================================================================
# Web (apps/web)
# ============================================================================

# Hosted mode API endpoint (leave empty for local-first Dexie mode)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Network: testnet only
NEXT_PUBLIC_DEFAULT_NETWORK=testnet

# Testnet (Chipnet) Electrum endpoint
NEXT_PUBLIC_TESTNET_ELECTRUM_URL=wss://chipnet.imaginary.cash:50004

# Optional: BCMR metadata registry URL
NEXT_PUBLIC_BCMR_REGISTRY_URL=

# Optional: block explorer base URL
NEXT_PUBLIC_TESTNET_EXPLORER_URL=https://chipnet.imaginary.cash

# Auto-lock timeout in minutes (0 = disabled)
NEXT_PUBLIC_AUTO_LOCK_MINUTES=15

# ============================================================================
# API (apps/api)
# ============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/cashdropkit

# JWT signing secret (min 32 chars; use a random 64-char hex)
SESSION_SECRET=replace-with-random-64-char-hex

# CORS allowlist (comma-separated) or *
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Electrum endpoint (testnet only)
ELECTRUM_TESTNET_URL=wss://chipnet.imaginary.cash:50004

# Worker tuning (optional)
WORKER_POLL_INTERVAL_MS=30000
WORKER_DROPPED_THRESHOLD_MS=1800000

# API server runtime (optional)
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
