# CashDrop Kit Root Environment Configuration
# Single source of truth for Web + API.
# 1) Copy to .env.local for local development
# 2) On Vercel/Railway, set the same keys in each service dashboard

# ============================================================================
# Web (apps/web)
# ============================================================================

# FE hosted API endpoint/token are hardcoded in source for deployment simplicity.
# (apps/web/src/ui/components/shell/AppShell.tsx)

# Network: testnet only
NEXT_PUBLIC_DEFAULT_NETWORK=testnet

# Testnet (Chipnet) Electrum endpoint
NEXT_PUBLIC_TESTNET_ELECTRUM_URL=wss://chipnet.imaginary.cash:50004

# Optional: BCMR metadata registry URL
NEXT_PUBLIC_BCMR_REGISTRY_URL=

# Optional: block explorer base URL
NEXT_PUBLIC_TESTNET_EXPLORER_URL=https://chipnet.imaginary.cash

# WalletConnect Project ID (required for BCH extension wallet connection)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Auto-lock timeout in minutes (0 = disabled)
NEXT_PUBLIC_AUTO_LOCK_MINUTES=15

# ============================================================================
# API (apps/api)
# ============================================================================

# PostgreSQL connection string (local default)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cashdropkit

# JWT signing secret (optional if API_ACCESS_TOKEN is set)
SESSION_SECRET=2b531e8dddf398e4178d5f1f9abe60ae331f3f331b869a94269cb883e94f1d93

# CORS allowlist (comma-separated)
# Include production FE domains and local dev origin.
CORS_ALLOWED_ORIGINS=https://cashdropkit.com,https://www.cashdropkit.com,http://localhost:3000

# Optional: static shared Bearer token for simple deployment auth
# If set, API expects "Authorization: Bearer <API_ACCESS_TOKEN>"
API_ACCESS_TOKEN=cashdropkit-public-client-token

# Electrum endpoint (testnet only)
ELECTRUM_TESTNET_URL=wss://chipnet.imaginary.cash:50004

# Worker tuning (optional)
WORKER_POLL_INTERVAL_MS=30000
WORKER_DROPPED_THRESHOLD_MS=1800000

# API server runtime (optional)
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
