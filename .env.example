# CashDrop Kit Environment Configuration
# Copy this file to .env.local and fill in the values

# Network: testnet only
NEXT_PUBLIC_DEFAULT_NETWORK=testnet

# Chain Provider Endpoints (Fulcrum/ElectrumX compatible)
# Testnet (Chipnet)
NEXT_PUBLIC_TESTNET_ELECTRUM_URL=wss://chipnet.imaginary.cash:50004

# Optional: BCMR Registry URL for token metadata
NEXT_PUBLIC_BCMR_REGISTRY_URL=

# Optional: Testnet block explorer base URL
NEXT_PUBLIC_TESTNET_EXPLORER_URL=https://chipnet.imaginary.cash

# Security: Auto-lock timeout in minutes (0 = disabled)
NEXT_PUBLIC_AUTO_LOCK_MINUTES=15

# API URL for hosted mode (Railway backend). Leave empty for local-first (Dexie) mode.
NEXT_PUBLIC_API_URL=
