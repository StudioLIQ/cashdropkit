# CashDrop Kit — API Server (Railway)
# Copy to .env and fill in values

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/cashdropkit

# JWT signing secret — minimum 32 characters (required)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-64-char-hex-string-at-least-32

# CORS allowed origins — comma separated or * for dev (required in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Electrum endpoint (testnet only)
ELECTRUM_TESTNET_URL=wss://chipnet.imaginary.cash:50004

# Worker configuration (optional)
WORKER_POLL_INTERVAL_MS=30000
WORKER_DROPPED_THRESHOLD_MS=1800000

# Server configuration (optional, Railway auto-sets PORT)
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
